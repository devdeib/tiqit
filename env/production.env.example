# Production (Vercel Production)
# Copy values into Vercel → Settings → Environment Variables → Production

APP_ENV=production

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROD-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Must be your public Vercel/custom domain — NOT http://localhost:3000
APP_URL=https://your-app.vercel.app

HMAC_SECRET_V1=

# Live payment provider — mock must be off in production
SHAM_CASH_MOCK=false
SHAM_CASH_API_KEY=
# Optional — only if Sham Cash sends signed HTTP callbacks (most accounts are API-key-only)
# SHAM_CASH_WEBHOOK_SECRET=
SHAM_CASH_API_BASE_URL=https://api.shamcash.example

ALLOW_DEV_PAYMENT=false

ADMIN_API_SECRET=
LOG_FORMAT=json
