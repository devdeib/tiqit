# Staging (Vercel Preview or dedicated staging project)
# Copy values into Vercel → Settings → Environment Variables → Preview

APP_ENV=staging

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Staging app URL — set to the stable preview URL or custom domain
APP_URL=https://staging.tiqit.example.com

HMAC_SECRET_V1=

# Staging defaults to mock checkout (even if SHAM_CASH_API_KEY is set).
# Optional: SHAM_CASH_MOCK=true forces mock; SHAM_CASH_FORCE_LIVE=true tests live adapter.
SHAM_CASH_MOCK=true
SHAM_CASH_API_KEY=
SHAM_CASH_FORCE_LIVE=false
SHAM_CASH_WEBHOOK_SECRET=
SHAM_CASH_API_BASE_URL=

# Optional: allow /api/dev/simulate-payment on staging only
ALLOW_DEV_PAYMENT=false

# Emergency admin APIs (inspect order, resend tickets, release reservation)
ADMIN_API_SECRET=

# Structured JSON logs on Vercel preview
LOG_FORMAT=json
